# Slack App credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Air Traffic configuration
ATC_MACHINE_NAME=desktop
ATC_PROJECTS_DIR=C:\dev\projects
ATC_DATA_DIR=C:\dev\air-traffic\data
ATC_DEFAULT_MODEL=claude-sonnet-4.5
ATC_LOG_LEVEL=info

# Timeout for permission prompts (ms, default 5 minutes)
ATC_PERMISSION_TIMEOUT_MS=300000
# Timeout for question prompts (ms, default 5 minutes)
ATC_QUESTION_TIMEOUT_MS=300000

# Console web server port
ATC_WEB_PORT=8089
